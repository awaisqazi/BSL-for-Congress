---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<nav class="navbar" id="navbar">
  <div class="nav-inner container-wide">
    <!-- Logo -->
    <a href={`${base}/`} class="nav-logo">
      <img src={`${base}/BSL_Official.png`} alt="Byron Sigcho-Lopez for Congress" class="logo-img" />
    </a>

    <!-- Desktop Navigation -->
    <ul class="nav-links hide-mobile">
      <li><a href={`${base}/meet`} data-i18n="nav.meet">Meet Byron</a></li>
      <li><a href={`${base}/platform`} data-i18n="nav.platform">The Platform</a></li>
      <li><a href={`${base}/movement`} data-i18n="nav.movement">Machine vs. Movement</a></li>
      <li><a href={`${base}/volunteer`} data-i18n="nav.volunteer">Volunteer</a></li>
    </ul>

    <!-- Right-side actions -->
    <div class="nav-actions">
      <!-- Language Toggle -->
      <div class="lang-toggle">
        <button data-lang-toggle="en" class="lang-btn active" aria-label="English">EN</button>
        <span class="lang-divider">/</span>
        <button data-lang-toggle="es" class="lang-btn" aria-label="Español">ES</button>
      </div>

      <!-- Donate Button -->
      <a href="https://secure.actblue.com/donate/byronfor04web/" class="btn btn-orange nav-donate" target="_blank" rel="noopener" data-i18n="nav.donate">Donate</a>

      <!-- Mobile Hamburger -->
      <button class="hamburger hide-desktop" id="hamburger" aria-label="Menu" aria-expanded="false">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Drawer -->
  <div class="mobile-drawer" id="mobile-drawer">
    <ul class="mobile-links">
      <li><a href={`${base}/meet`} data-i18n="nav.meet">Meet Byron</a></li>
      <li><a href={`${base}/platform`} data-i18n="nav.platform">The Platform</a></li>
      <li><a href={`${base}/movement`} data-i18n="nav.movement">Machine vs. Movement</a></li>
      <li><a href={`${base}/volunteer`} data-i18n="nav.volunteer">Volunteer</a></li>
      <li>
        <a href="https://secure.actblue.com/donate/byronfor04web/" class="btn btn-orange mobile-donate" target="_blank" rel="noopener" data-i18n="nav.donate">Donate</a>
      </li>
    </ul>
    <div class="mobile-social">
      <a href="https://www.instagram.com/bslforcongress/" class="mobile-social-link" aria-label="Instagram" target="_blank" rel="noopener">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
      </a>
      <a href="https://www.tiktok.com/@sigchofor25" class="mobile-social-link" aria-label="TikTok" target="_blank" rel="noopener">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.75a8.23 8.23 0 0 0 4.76 1.51V6.82a4.83 4.83 0 0 1-1-.13z"/></svg>
      </a>
      <a href="https://www.facebook.com/BSLForCongress/" class="mobile-social-link" aria-label="Facebook" target="_blank" rel="noopener">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
      <a href="https://x.com/BSLForCongress" class="mobile-social-link" aria-label="X / Twitter" target="_blank" rel="noopener">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
    </div>
  </div>
</nav>

<script>
  const hamburger = document.getElementById('hamburger');
  const drawer = document.getElementById('mobile-drawer');
  const navbar = document.getElementById('navbar');
  
  hamburger?.addEventListener('click', () => {
    const isOpen = drawer?.classList.toggle('open');
    hamburger.classList.toggle('active');
    hamburger.setAttribute('aria-expanded', String(isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  // Close drawer on link click
  drawer?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      drawer.classList.remove('open');
      hamburger?.classList.remove('active');
      document.body.style.overflow = '';
    });
  });

  // Navbar background on scroll
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  });
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    height: var(--nav-height);
    transition: all var(--duration-normal) var(--ease-default);
    background: rgba(251, 226, 186, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .navbar.scrolled {
    background: rgba(251, 226, 186, 0.97);
    box-shadow: 0 2px 20px rgba(0,0,0,0.1);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  /* Logo */
  .nav-logo {
    display: flex;
    align-items: center;
    line-height: 1;
    transition: transform var(--duration-fast) var(--ease-default);
    flex-shrink: 0;
  }

  .nav-logo:hover {
    transform: scale(1.03);
  }

  .logo-img {
    height: 48px;
    width: auto;
    display: block;
  }

  /* Nav Links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
  }

  .nav-links a {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--blue-deeper);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: color var(--duration-fast) var(--ease-default);
    position: relative;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--orange);
    transition: width var(--duration-normal) var(--ease-default);
  }

  .nav-links a:hover {
    color: var(--orange);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  /* Actions */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  /* Lang Toggle */
  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 2px;
    background: rgba(5, 173, 237, 0.1);
    border-radius: var(--radius-md);
    padding: 4px 6px;
  }

  .lang-btn {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.75rem;
    color: var(--blue);
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    transition: all var(--duration-fast) var(--ease-default);
    letter-spacing: 0.05em;
  }

  .lang-btn.active {
    background: var(--blue);
    color: var(--white);
  }

  .lang-btn:hover:not(.active) {
    background: rgba(5, 173, 237, 0.15);
  }

  .lang-divider {
    color: var(--blue);
    opacity: 0.4;
    font-size: 0.75rem;
    font-weight: 300;
  }

  /* Donate */
  .nav-donate {
    font-size: var(--text-xs) !important;
    padding: 8px 20px !important;
    text-transform: uppercase !important;
    letter-spacing: 0.1em !important;
    animation: none !important;
  }

  /* Hamburger */
  .hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
  }

  .hamburger-line {
    display: block;
    width: 24px;
    height: 2.5px;
    background: var(--blue);
    border-radius: 2px;
    transition: all var(--duration-normal) var(--ease-default);
    transform-origin: center;
  }

  .hamburger.active .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .hamburger.active .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger.active .hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translate(6px, -6px);
  }

  /* Mobile Drawer */
  .mobile-drawer {
    position: fixed;
    top: var(--nav-height);
    left: 0;
    right: 0;
    bottom: 0;
    background: #fbe2ba;
    z-index: 1001;
    transform: translateX(100%);
    transition: transform var(--duration-normal) var(--ease-default);
    padding: var(--space-3xl) var(--space-2xl);
  }

  .mobile-drawer.open {
    transform: translateX(0);
  }

  .mobile-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .mobile-links a {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-2xl);
    color: var(--blue);
    display: block;
    padding: var(--space-sm) 0;
    border-bottom: 2px solid rgba(5, 173, 237, 0.1);
  }

  .mobile-donate {
    margin-top: var(--space-md);
    width: 100%;
    text-align: center;
    font-size: var(--text-lg) !important;
  }

  .mobile-social {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid rgba(5, 173, 237, 0.15);
  }

  .mobile-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(5, 173, 237, 0.12);
    color: var(--blue);
    transition: background var(--duration-fast) var(--ease-default), transform var(--duration-fast) var(--ease-default);
  }

  .mobile-social-link:hover {
    background: var(--orange);
    color: var(--white);
    transform: translateY(-2px);
  }
</style>
