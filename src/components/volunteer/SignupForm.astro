---
---

<section class="signup-section section-padding" id="signup">
  <div class="container">
    <div class="signup-grid">
      <div class="signup-text">
        <span class="section-label animate-in" data-i18n="volunteer.signup_label">Join the Movement</span>
        <h2 class="section-title animate-in" data-i18n="volunteer.signup_headline">Sign Up to Volunteer</h2>
        <p class="signup-desc animate-in" data-i18n="volunteer.signup_desc">
          Fill out the form and our team will reach out with next steps. Whether you have one hour or one hundred, there is a role for you in this movement.
        </p>
      </div>

      <form class="signup-form animate-in" id="volunteer-form" action="#" method="POST">
        <div class="form-row">
          <div class="form-group">
            <label for="first-name" data-i18n="volunteer.label_first">First Name *</label>
            <input type="text" id="first-name" name="first_name" required />
          </div>
          <div class="form-group">
            <label for="last-name" data-i18n="volunteer.label_last">Last Name *</label>
            <input type="text" id="last-name" name="last_name" required />
          </div>
        </div>

        <div class="form-group">
          <label for="email" data-i18n="volunteer.label_email">Email *</label>
          <input type="email" id="email" name="email" required />
        </div>

        <div class="form-row form-row-3">
          <div class="form-group">
            <label for="phone" data-i18n="volunteer.label_phone">Mobile Phone *</label>
            <input type="tel" id="phone" name="phone" required />
          </div>
          <div class="form-group">
            <label for="city" data-i18n="volunteer.label_city">City *</label>
            <input type="text" id="city" name="city" required />
          </div>
          <div class="form-group">
            <label for="zip" data-i18n="volunteer.label_zip">ZIP Code *</label>
            <input type="text" id="zip" name="zip_code" pattern="[0-9]{5}" required />
          </div>
        </div>

        <fieldset class="form-checkboxes">
          <legend data-i18n="volunteer.help_legend">How would you like to help?</legend>

          <label class="checkbox-label">
            <input type="checkbox" name="help[]" value="petition" />
            <span class="checkbox-text" data-i18n="volunteer.check_petition">Collect Petition Signatures</span>
          </label>

          <label class="checkbox-label">
            <input type="checkbox" name="help[]" value="canvass" />
            <span class="checkbox-text" data-i18n="volunteer.check_canvass">Knock on Doors</span>
          </label>

          <label class="checkbox-label">
            <input type="checkbox" name="help[]" value="phone" />
            <span class="checkbox-text" data-i18n="volunteer.check_phone">Phone/Text Banking</span>
          </label>

          <label class="checkbox-label">
            <input type="checkbox" name="help[]" value="host" />
            <span class="checkbox-text" data-i18n="volunteer.check_host">Host a Meet & Greet</span>
          </label>

          <label class="checkbox-label">
            <input type="checkbox" name="help[]" value="bilingual" />
            <span class="checkbox-text" data-i18n="volunteer.check_bilingual">Bilingual Outreach (I speak Spanish / Yo hablo español)</span>
          </label>

          <label class="checkbox-label">
            <input type="checkbox" name="help[]" value="social_media" />
            <span class="checkbox-text" data-i18n="volunteer.check_social_media">Post on Social Media</span>
          </label>

          <label class="checkbox-label">
            <input type="checkbox" name="help[]" value="precinct_captain" />
            <span class="checkbox-text" data-i18n="volunteer.check_precinct_captain">Precinct Captain / Volunteer</span>
          </label>

          <label class="checkbox-label">
            <input type="checkbox" name="help[]" value="hs_ambassador" />
            <span class="checkbox-text" data-i18n="volunteer.check_hs_ambassador">High School Ambassador</span>
          </label>

          <label class="checkbox-label">
            <input type="checkbox" name="help[]" value="college_captain" />
            <span class="checkbox-text" data-i18n="volunteer.check_college_captain">College Campus Captain / Volunteer</span>
          </label>

          <label class="checkbox-label">
            <input type="checkbox" name="help[]" value="marketing" />
            <span class="checkbox-text" data-i18n="volunteer.check_marketing">Help Create Marketing Collateral (Graphic Design)</span>
          </label>

          <label class="checkbox-label">
            <input type="checkbox" name="help[]" value="videos" />
            <span class="checkbox-text" data-i18n="volunteer.check_videos">Help Create Campaign Videos (Videography / Video Editing)</span>
          </label>
        </fieldset>

        <p class="form-compliance" data-i18n="volunteer.compliance">
          By submitting, you agree to receive periodic campaign updates via SMS. Message and data rates may apply. Text STOP to unsubscribe.
        </p>

        <button type="submit" class="btn btn-orange btn-massive form-submit" data-i18n="volunteer.submit">
          Join the Movement
        </button>
      </form>
    </div>
  </div>
</section>

<!-- Fund the Fight CTA -->
<section class="volunteer-cta-block">
  <div class="volunteer-cta-bg">
    <div class="volunteer-cta-pattern"></div>
  </div>
  <div class="container volunteer-cta-content">
    <h2 class="volunteer-cta-headline animate-in" data-i18n="volunteer.cta_headline">Can't Volunteer Today? Fund the Fight.</h2>
    <p class="volunteer-cta-text animate-in" data-i18n="volunteer.cta_text">
      Every dollar helps buy clipboards, literature, and digital tools for the volunteer army. This campaign is entirely unbought and funded by working people like you.
    </p>
    <div class="volunteer-cta-buttons animate-in">
      <a href="https://secure.actblue.com/donate/byronfor04web/" class="btn btn-orange btn-massive" target="_blank" rel="noopener" data-i18n="volunteer.cta_donate">Chip in $27</a>
    </div>
  </div>
</section>

<style>
  .signup-section {
    background: var(--cream);
  }

  .signup-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: var(--space-4xl);
    align-items: start;
  }

  .signup-desc {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--gray-700);
    margin-top: var(--space-md);
  }

  .signup-text {
    position: sticky;
    top: calc(var(--nav-height, 80px) + var(--space-xl));
  }

  /* Form Styles */
  .signup-form {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    box-shadow: var(--shadow-md);
    border: 2px solid rgba(5, 173, 237, 0.1);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .form-row-3 {
    grid-template-columns: 1fr 1fr 1fr;
  }

  .form-group {
    margin-bottom: var(--space-lg);
  }

  .form-group label {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--blue);
    margin-bottom: 6px;
  }

  .form-group input {
    width: 100%;
    padding: 12px 16px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    border: 2px solid rgba(5, 173, 237, 0.2);
    border-radius: var(--radius-md);
    background: var(--cream-light);
    color: var(--black);
    transition: border-color var(--duration-fast) var(--ease-default), box-shadow var(--duration-fast) var(--ease-default);
    box-sizing: border-box;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(5, 173, 237, 0.15);
  }

  /* Checkboxes */
  .form-checkboxes {
    border: none;
    padding: 0;
    margin: 0 0 var(--space-lg) 0;
  }

  .form-checkboxes legend {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--blue);
    margin-bottom: var(--space-md);
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 10px 0;
    cursor: pointer;
    border-bottom: 1px solid rgba(5, 173, 237, 0.06);
    transition: background var(--duration-fast) var(--ease-default);
  }

  .checkbox-label:last-child {
    border-bottom: none;
  }

  .checkbox-label:hover {
    background: rgba(5, 173, 237, 0.02);
  }

  .checkbox-label input[type="checkbox"] {
    width: 20px;
    height: 20px;
    accent-color: var(--orange);
    cursor: pointer;
    flex-shrink: 0;
  }

  .checkbox-text {
    font-size: var(--text-sm);
    color: var(--gray-700);
    line-height: 1.4;
  }

  /* Compliance */
  .form-compliance {
    font-size: var(--text-xs);
    line-height: 1.5;
    color: var(--gray-500);
    margin-bottom: var(--space-lg);
  }

  /* Submit */
  .form-submit {
    width: 100%;
    font-size: var(--text-lg) !important;
    padding: 18px 32px !important;
    cursor: pointer;
    border: none;
  }

  /* CTA Block */
  .volunteer-cta-block {
    position: relative;
    padding: var(--space-4xl) 0;
    overflow: hidden;
  }

  .volunteer-cta-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--blue) 0%, var(--blue-deeper) 100%);
    z-index: 0;
  }

  .volunteer-cta-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    background-image: radial-gradient(circle at 30% 50%, rgba(255,255,255,0.1) 0%, transparent 50%);
  }

  .volunteer-cta-content {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
  }

  .volunteer-cta-headline {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 900;
    color: var(--cream);
    text-transform: uppercase;
    max-width: 700px;
  }

  .volunteer-cta-text {
    font-size: var(--text-lg);
    line-height: 1.7;
    color: #ffffff;
    max-width: 650px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .signup-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .form-row,
    .form-row-3 {
      grid-template-columns: 1fr;
    }

    .volunteer-cta-headline {
      font-size: var(--text-2xl);
    }
  }
</style>
