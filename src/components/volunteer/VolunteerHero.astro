---
---

<section class="volunteer-hero" id="volunteer-hero">
  <div class="volunteer-hero-overlay"></div>
  <div class="volunteer-hero-noise"></div>

  <div class="volunteer-hero-content container">
    <span class="volunteer-hero-badge animate-in" data-i18n="volunteer.hero_badge">TAKE ACTION</span>

    <h1 class="volunteer-hero-headline animate-in" data-i18n="volunteer.hero_headline">
      We Are The Machine's Worst Nightmare.
    </h1>

    <p class="volunteer-hero-sub animate-in" data-i18n="volunteer.hero_sub">
      We don't have corporate PAC money or backroom bosses. We have you. Join the multiracial working-class coalition to take back IL-04.
    </p>
  </div>
</section>

<style>
  .volunteer-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-image: url('/images/volunteer-hero-placeholder.png');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    overflow: hidden;
    padding-top: var(--nav-height);
  }

  @media (max-width: 768px) {
    .volunteer-hero {
      background-attachment: scroll;
      min-height: 60vh;
    }
  }

  .volunteer-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      rgba(5, 173, 237, 0.92) 0%,
      rgba(3, 109, 153, 0.88) 40%,
      rgba(26, 26, 26, 0.82) 100%
    );
    z-index: 1;
  }

  .volunteer-hero-noise {
    position: absolute;
    inset: 0;
    z-index: 2;
    opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    pointer-events: none;
  }

  .volunteer-hero-content {
    position: relative;
    z-index: 3;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    max-width: 900px;
    padding: var(--space-4xl) var(--space-lg);
  }

  .volunteer-hero-badge {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.25em;
    color: var(--cream);
    background: rgba(230, 136, 28, 0.25);
    border: 1px solid rgba(230, 136, 28, 0.45);
    padding: 6px 18px;
    border-radius: 100px;
    backdrop-filter: blur(4px);
  }

  .volunteer-hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 900;
    line-height: 1.05;
    color: var(--cream);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    text-shadow: 0 4px 40px rgba(0,0,0,0.4);
  }

  .volunteer-hero-sub {
    font-family: var(--font-body);
    font-size: var(--text-xl);
    font-weight: 400;
    line-height: 1.6;
    color: #ffffff;
    max-width: 750px;
  }

  @media (max-width: 768px) {
    .volunteer-hero-content {
      padding: var(--space-3xl) var(--space-md);
    }
  }
</style>
