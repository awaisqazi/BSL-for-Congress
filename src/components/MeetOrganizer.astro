---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="bio section-padding" id="meet">
  <div class="container">
    <div class="bio-grid">
      <!-- Image -->
      <div class="bio-image-wrap animate-in">
        <div class="bio-image-accent"></div>
        <img 
          src={`${base}/images/bslfamily.jpg`} 
          alt="Byron Sigcho-Lopez with family"
          class="bio-image"
          loading="lazy"
        />
      </div>

      <!-- Text -->
      <div class="bio-text">
        <span class="section-label animate-in" data-i18n="bio.label">Meet Byron</span>
        <h2 class="section-title animate-in" data-i18n="bio.headline">He wasn't born here, but he followed his heart home as quickly as he could.</h2>
        
        <p class="bio-paragraph animate-in" data-i18n="bio.p1">
          Byron is an immigrant who came to the United States alone when he was 17 years old. His life is a testament to what happens when strangers become neighbors and family.
        </p>
        
        <p class="bio-paragraph animate-in" data-i18n="bio.p2">
          Byron Sigcho Lopez is the only elected official in this race who has delivered material benefits for the working people of Chicagoland, with a record of coalition building with every neighbor willing to come together to solve the problems we face, together. He has courageously fought the corruption of the Illinois political machine, helping take down corrupt charter school networks looting from our children's future, and even taking campaign finance corruption all the way to the Illinois Supreme Court.
        </p>

        <p class="bio-paragraph animate-in" data-i18n="bio.p3">
          Byron earned his Bachelor's in Mathematics and Business Administration from Cumberland University and his Master's in Economics from the University of Illinois at Chicago.
        </p>

        <p class="bio-paragraph animate-in" data-i18n="bio.p4">
          Byron lives in the Pilsen neighborhood with his wife, Loreen, their 3-year-old triplets, a dog, and two cats.
        </p>

        <a href={`${base}/meet`} class="btn btn-outline bio-cta animate-in" data-i18n="bio.cta">
          Read Byron's Full Story
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .bio {
    background: var(--cream);
    position: relative;
    overflow: hidden;
  }

  .bio::before {
    content: '';
    position: absolute;
    top: -80px;
    left: -80px;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(5, 173, 237, 0.06) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .bio-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  /* Image */
  .bio-image-wrap {
    position: relative;
  }

  .bio-image-accent {
    position: absolute;
    top: -12px;
    left: -12px;
    right: 12px;
    bottom: 12px;
    border: 3px solid var(--orange);
    border-radius: var(--radius-lg);
    z-index: 0;
  }

  .bio-image {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 500px;
    object-fit: cover;
    object-position: 35% center;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  .bio-image-tag {
    position: absolute;
    bottom: 16px;
    left: 16px;
    z-index: 2;
    background: rgba(26, 26, 26, 0.7);
    backdrop-filter: blur(8px);
    color: var(--cream);
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 6px 14px;
    border-radius: 100px;
    letter-spacing: 0.03em;
  }

  /* Text */
  .bio-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .bio-paragraph {
    font-size: var(--text-base);
    line-height: 1.75;
    color: var(--gray-700);
  }

  .bio-cta {
    align-self: flex-start;
    margin-top: var(--space-md);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .bio-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .bio-image {
      height: 400px;
    }
  }

  @media (max-width: 768px) {
    .bio-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .bio-image {
      height: 300px;
    }

    .bio-image-accent {
      top: -8px;
      left: -8px;
      right: 8px;
      bottom: 8px;
    }
  }
</style>
