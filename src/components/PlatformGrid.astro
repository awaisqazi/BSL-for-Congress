---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="platform section-padding" id="platform">
  <div class="container">
    <div class="platform-header">
      <span class="section-label animate-in" data-i18n="platform.label">The Platform</span>
      <h2 class="section-title animate-in" data-i18n="platform.headline">Where everybody has a home, and everybody eats.</h2>
    </div>

    <div class="platform-grid">
      <!-- Housing -->
      <div class="platform-card animate-in" data-accent="housing">
        <div class="card-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </div>
        <h3 class="card-title" data-i18n="platform.housing.title">Housing as a Human Right</h3>
        <p class="card-desc" data-i18n="platform.housing.desc">Our country can and must provide dignified and safe housing for every veteran and neighbor who needs a helping hand. National tenant bill of rights and expand social housing developments to lower the rent and lower the cost of buying a home.</p>
        <div class="card-accent-line"></div>
      </div>

      <!-- Economy -->
      <div class="platform-card animate-in" data-accent="economic">
        <div class="card-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 20h10"/>
            <path d="M10 20c5.5-2.5.8-6.4 3-10"/>
            <path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"/>
            <path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"/>
          </svg>
        </div>
        <h3 class="card-title" data-i18n="platform.economic.title">An Economy Putting People and Planet First</h3>
        <p class="card-desc" data-i18n="platform.economic.desc">Tax the billionaires and invest our resources in creating sustainable union jobs for every worker in our communities. Raise the minimum wage to $30/hour. No bailouts for banks or tech bubbles. Investments in supporting local entrepreneurs across IL-04. Civilian climate corps jobs for green energy, natural spaces, and community resilience.</p>
        <div class="card-accent-line"></div>
      </div>

      <!-- Education -->
      <div class="platform-card animate-in" data-accent="education">
        <div class="card-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
            <path d="M6 12v5c3 3 9 3 12 0v-5"/>
          </svg>
        </div>
        <h3 class="card-title" data-i18n="platform.education.title">Literacy, Curiosity, Creativity, and Inspiration Now</h3>
        <p class="card-desc" data-i18n="platform.education.desc">Every student, 0 to 100, deserves the opportunity to be inspired, pursue their curiosity, nurture their creativity, and expand their literacy. Fight to restore the U.S. Department of Education. Invest in fully funded public education and provide every student and family with robust wraparound services and extracurricular activities.</p>
        <div class="card-accent-line"></div>
      </div>

      <!-- Healthcare -->
      <div class="platform-card animate-in" data-accent="healthcare">
        <div class="card-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
            <path d="M3.22 12H9.5l.5-1 2 4.5 2-7 1.5 3.5h5.27"/>
          </svg>
        </div>
        <h3 class="card-title" data-i18n="platform.healthcare.title">Healthcare for All</h3>
        <p class="card-desc" data-i18n="platform.healthcare.desc">Our resources are not endless and not one more dollar should go to greedy middlemen who do not improve the health of our people. We must pass Medicare for All, and exponentially grow our investment in the National Institutes of Health (NIH) to put more of our most curious people spending their time eliminating and curing premature causes of death or chronic illnesses like heart disease, cancer, and mental illness.</p>
        <div class="card-accent-line"></div>
      </div>

      <!-- Immigration -->
      <div class="platform-card animate-in" data-accent="immigration">
        <div class="card-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <h3 class="card-title" data-i18n="platform.immigration.title">Abolish ICE, Create a Pathway to Citizenship for Our Neighbors</h3>
        <p class="card-desc" data-i18n="platform.immigration.desc">No human being is illegal. Abolish ICE and end the militarized deportation machine terrorizing our communities. Ban ICE from operating on public property, shut down detention centers, and end the surveillance state targeting immigrant families. Create a clear, humane pathway to citizenship for the millions of neighbors who build our communities every day.</p>
        <div class="card-accent-line"></div>
      </div>

      <!-- Foreign Policy -->
      <div class="platform-card animate-in" data-accent="foreign-policy">
        <div class="card-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
            <path d="M2 12h20"/>
          </svg>
        </div>
        <h3 class="card-title" data-i18n="platform.foreignpolicy.title">Foreign Policy</h3>
        <p class="card-desc" data-i18n="platform.foreignpolicy.desc">No taxpayer dollars for apartheid and genocide. End all military aid and weapons shipments sustaining the occupation of Palestine and the genocide of its people. End the illegal, unauthorized war with Iran. Prohibit investment in Israel Bonds and contracts with corporations manufacturing weapons used for ethnic cleansing. Demand an end to U.S. imperialism and redirect those billions toward our communities at home.</p>
        <div class="card-accent-line"></div>
      </div>
    </div>

    <div class="platform-cta-wrap animate-in">
      <a href={`${base}/platform`} class="btn btn-orange" data-i18n="platform.cta">Read the Full Platform</a>
    </div>
  </div>
</section>

<style>
  .platform {
    background: var(--cream-light);
    position: relative;
  }

  .platform::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--blue), var(--orange), var(--blue));
  }

  .platform-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .platform-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }

  .platform-card {
    background: var(--white);
    border-radius: var(--radius-xl);
    padding: var(--space-2xl);
    position: relative;
    overflow: hidden;
    transition: all var(--duration-normal) var(--ease-default);
    border: 1px solid rgba(5, 173, 237, 0.08);
  }

  .platform-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: rgba(5, 173, 237, 0.2);
  }

  .card-icon {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--blue);
    margin-bottom: var(--space-lg);
    background: rgba(5, 173, 237, 0.08);
    border-radius: var(--radius-lg);
    padding: 8px;
    transition: all var(--duration-normal) var(--ease-default);
  }

  .platform-card:hover .card-icon {
    background: var(--blue);
    color: var(--white);
    transform: scale(1.05);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--blue);
    margin-bottom: var(--space-sm);
    line-height: 1.2;
  }

  .card-desc {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--gray-700);
  }

  .card-accent-line {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--orange);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--duration-normal) var(--ease-default);
  }

  .platform-card:hover .card-accent-line {
    transform: scaleX(1);
  }

  .platform-cta-wrap {
    text-align: center;
    margin-top: var(--space-3xl);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .platform-grid {
      grid-template-columns: 1fr;
    }

    .platform-card {
      padding: var(--space-xl);
    }
  }
</style>
