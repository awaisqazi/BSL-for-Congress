---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="platform section-padding" id="platform">
  <div class="container">
    <div class="platform-header">
      <span class="section-label animate-in" data-i18n="platform.label">The Platform</span>
      <h2 class="section-title animate-in" data-i18n="platform.headline">Where everybody has a home, and everybody eats.</h2>
    </div>

    <div class="platform-grid">
      <!-- Housing -->
      <div class="platform-card animate-in" data-accent="housing">
        <div class="card-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </div>
        <h3 class="card-title" data-i18n="platform.housing.title">Housing for every veteran and all our neighbors</h3>
        <p class="card-desc" data-i18n="platform.housing.desc">More than 10,000 veterans lost their homes to foreclosure and 90,000 more are at risk. Byron will fight for a national tenant bill of rights, expanded social housing, and real power structures to bring housing dignity to every neighbor.</p>
        <div class="card-accent-line"></div>
      </div>

      <!-- Medicare for All -->
      <div class="platform-card animate-in" data-accent="healthcare">
        <div class="card-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
            <path d="M3.22 12H9.5l.5-1 2 4.5 2-7 1.5 3.5h5.27"/>
          </svg>
        </div>
        <h3 class="card-title" data-i18n="platform.healthcare.title">Medicare for all</h3>
        <p class="card-desc" data-i18n="platform.healthcare.desc">Not one more dollar to greedy middlemen. Byron will pass Medicare for All, grow NIH investment, expand teaching hospitals, eliminate maternal infant mortality disparities, and ensure healthcare includes reproductive care, mental health, and parental time off.</p>
        <div class="card-accent-line"></div>
      </div>

      <!-- Green Jobs -->
      <div class="platform-card animate-in" data-accent="economic">
        <div class="card-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 20h10"/>
            <path d="M10 20c5.5-2.5.8-6.4 3-10"/>
            <path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"/>
            <path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"/>
          </svg>
        </div>
        <h3 class="card-title" data-i18n="platform.economic.title">Green jobs. Local economies. A livable future.</h3>
        <p class="card-desc" data-i18n="platform.economic.desc">Tax billionaires and invest in local economies. Raise the minimum wage to $30/hour. Support local entrepreneurs. Civilian climate corp jobs for green energy, public transit, and community resilience against storms, floods, and disasters.</p>
        <div class="card-accent-line"></div>
      </div>

      <!-- Democracy -->
      <div class="platform-card animate-in" data-accent="democracy">
        <div class="card-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/>
            <line x1="4" x2="4" y1="22" y2="15"/>
          </svg>
        </div>
        <h3 class="card-title" data-i18n="platform.democracy.title">Democracy for the people, not for billionaires and corporations</h3>
        <p class="card-desc" data-i18n="platform.democracy.desc">End dark money, ban congressional stock trading, pass automatic voter registration, make Election Day a holiday, restore the Voting Rights Act, and pursue the Epstein Files. No corporate PACs. Democracy belongs to every single one of us.</p>
        <div class="card-accent-line"></div>
      </div>
    </div>

    <div class="platform-cta-wrap animate-in">
      <a href={`${base}/platform`} class="btn btn-orange" data-i18n="platform.cta">Read the Full Platform</a>
    </div>
  </div>
</section>

<style>
  .platform {
    background: var(--cream-light);
    position: relative;
  }

  .platform::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--blue), var(--orange), var(--blue));
  }

  .platform-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .platform-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }

  .platform-card {
    background: var(--white);
    border-radius: var(--radius-xl);
    padding: var(--space-2xl);
    position: relative;
    overflow: hidden;
    transition: all var(--duration-normal) var(--ease-default);
    border: 1px solid rgba(5, 173, 237, 0.08);
  }

  .platform-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: rgba(5, 173, 237, 0.2);
  }

  .card-icon {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--blue);
    margin-bottom: var(--space-lg);
    background: rgba(5, 173, 237, 0.08);
    border-radius: var(--radius-lg);
    padding: 8px;
    transition: all var(--duration-normal) var(--ease-default);
  }

  .platform-card:hover .card-icon {
    background: var(--blue);
    color: var(--white);
    transform: scale(1.05);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--blue);
    margin-bottom: var(--space-sm);
    line-height: 1.2;
  }

  .card-desc {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--gray-700);
  }

  .card-accent-line {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--orange);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--duration-normal) var(--ease-default);
  }

  .platform-card:hover .card-accent-line {
    transform: scaleX(1);
  }

  .platform-cta-wrap {
    text-align: center;
    margin-top: var(--space-3xl);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .platform-card {
      padding: var(--space-xl) var(--space-xl);
    }

    .platform-grid {
      gap: var(--space-lg);
    }
  }

  @media (max-width: 768px) {
    .platform-grid {
      grid-template-columns: 1fr;
    }

    .platform-card {
      padding: var(--space-xl);
    }
  }
</style>
