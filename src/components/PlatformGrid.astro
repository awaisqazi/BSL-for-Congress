---
---

<section class="platform section-padding" id="platform">
  <div class="container">
    <div class="platform-header">
      <span class="section-label animate-in" data-i18n="platform.label">The Platform</span>
      <h2 class="section-title animate-in" data-i18n="platform.headline">A Working-Class Agenda for IL-04</h2>
    </div>

    <div class="platform-grid">
      <!-- Housing -->
      <div class="platform-card animate-in" data-accent="housing">
        <div class="card-icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M24 4L4 20V44H18V30H30V44H44V20L24 4Z" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M18 30H30V44H18V30Z" stroke="currentColor" stroke-width="3"/>
          </svg>
        </div>
        <h3 class="card-title" data-i18n="platform.housing.title">Housing as a Human Right</h3>
        <p class="card-desc" data-i18n="platform.housing.desc">Stop displacement. Fight for rent control. Build truly affordable housing, not luxury condos rebranded as 'mixed-income.'</p>
        <div class="card-accent-line"></div>
      </div>

      <!-- Economic -->
      <div class="platform-card animate-in" data-accent="economic">
        <div class="card-icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="24" cy="24" r="20" stroke="currentColor" stroke-width="3"/>
            <path d="M24 12V36M18 18C18 15.8 20.7 14 24 14S30 15.8 30 18C30 21 24 22 24 24C24 26 24 26 24 26M18 30C18 32.2 20.7 34 24 34S30 32.2 30 30" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="card-title" data-i18n="platform.economic.title">Economic Populism</h3>
        <p class="card-desc" data-i18n="platform.economic.desc">Tax the rich. Cap property taxes for working families. End corporate welfare and invest in the neighborhoods that have been disinvested for decades.</p>
        <div class="card-accent-line"></div>
      </div>

      <!-- Labor -->
      <div class="platform-card animate-in" data-accent="labor">
        <div class="card-icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M24 4C20 4 16 8 16 14V20H12V44H36V20H32V14C32 8 28 4 24 4Z" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M20 28L24 32L28 28" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M24 20V32" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="card-title" data-i18n="platform.labor.title">Labor & Public Education</h3>
        <p class="card-desc" data-i18n="platform.labor.desc">Stand with the CTU and every union fighting for dignity. Fully fund public schools. Stop the privatization pipeline that guts working-class communities.</p>
        <div class="card-accent-line"></div>
      </div>

      <!-- Environment -->
      <div class="platform-card animate-in" data-accent="environment">
        <div class="card-icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M24 44V24" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
            <path d="M24 24C24 24 12 20 12 10C12 6 16 4 20 6C22 7 24 10 24 10C24 10 26 7 28 6C32 4 36 6 36 10C36 20 24 24 24 24Z" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M16 38C16 38 20 34 24 34C28 34 32 38 32 38" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="card-title" data-i18n="platform.environment.title">Environmental Justice</h3>
        <p class="card-desc" data-i18n="platform.environment.desc">Hold toxic polluters accountable. No more sacrifice zones in Black and Brown neighborhoods. Clean air, clean water for everyone, not just the wealthy.</p>
        <div class="card-accent-line"></div>
      </div>
    </div>

    <div class="platform-cta-wrap animate-in">
      <a href="/platform" class="btn btn-orange" data-i18n="platform.cta">Read the Full Platform</a>
    </div>
  </div>
</section>

<style>
  .platform {
    background: var(--cream-light);
    position: relative;
  }

  .platform::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--blue), var(--orange), var(--blue));
  }

  .platform-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .platform-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }

  .platform-card {
    background: var(--white);
    border-radius: var(--radius-xl);
    padding: var(--space-2xl);
    position: relative;
    overflow: hidden;
    transition: all var(--duration-normal) var(--ease-default);
    border: 1px solid rgba(5, 173, 237, 0.08);
  }

  .platform-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: rgba(5, 173, 237, 0.2);
  }

  .card-icon {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--blue);
    margin-bottom: var(--space-lg);
    background: rgba(5, 173, 237, 0.08);
    border-radius: var(--radius-lg);
    padding: 8px;
    transition: all var(--duration-normal) var(--ease-default);
  }

  .platform-card:hover .card-icon {
    background: var(--blue);
    color: var(--white);
    transform: scale(1.05);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--blue);
    margin-bottom: var(--space-sm);
    line-height: 1.2;
  }

  .card-desc {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--gray-700);
  }

  .card-accent-line {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--orange);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--duration-normal) var(--ease-default);
  }

  .platform-card:hover .card-accent-line {
    transform: scaleX(1);
  }

  .platform-cta-wrap {
    text-align: center;
    margin-top: var(--space-3xl);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .platform-grid {
      grid-template-columns: 1fr;
    }

    .platform-card {
      padding: var(--space-xl);
    }
  }
</style>
