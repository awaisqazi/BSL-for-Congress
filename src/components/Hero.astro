---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="hero" id="hero">
  <!-- Video Background -->
  <div class="hero-video-bg">
    <div class="hero-video-container" id="heroVideoContainer">
      <iframe
        id="heroVideo"
        src="https://www.youtube.com/embed/ouSFDZfJu-E?autoplay=1&mute=1&loop=1&playlist=ouSFDZfJu-E&controls=0&showinfo=0&modestbranding=1&playsinline=1&enablejsapi=1"
        title="Byron Sigcho-Lopez: The People's Fighter"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen
      ></iframe>
    </div>
    <!-- Gradient Overlay -->
    <div class="hero-gradient-overlay" id="heroGradientOverlay"></div>
  </div>

  <!-- Content Overlay -->
  <div class="hero-content-overlay" id="heroContentOverlay">
    <div class="hero-content container">
      <span class="hero-badge animate-in">INDEPENDENT DEMOCRATIC SOCIALIST • IL-04</span>

      <h1 class="hero-headline animate-in" data-i18n="hero.headline">
        Everybody has a home, and everybody eats.
      </h1>

      <p class="hero-subheadline animate-in" data-i18n="hero.subheadline">
        Byron Sigcho Lopez is a husband, father of little triplets, math teacher & economist, naturalized immigrant, and two-term elected Democratic Socialist Alderman from Chicago's Pilsen neighborhood.
      </p>

      <a href="#petition" class="btn btn-orange btn-massive hero-cta animate-in" data-i18n="hero.cta">
        Join the Petition Blitz
      </a>

      <p class="hero-context animate-in" data-i18n="hero.context">
        The Democratic Primary Election in IL-04's Congressional District was rigged! On March 17th, many of our neighbors across Illinois had 5+ choices on their Democratic Primary ballot. Voters in our district only had ONE because the political establishment chose on our behalf. Byron needs over 10,816 valid petition signatures in order to appear on your ballot on November 3rd. We need your help to overcome a system rigged against unbought candidates!
      </p>

    </div>
  </div>

  <!-- Sound Toggle Button (outside content overlay so it stays visible) -->
  <button class="hero-sound-btn" id="heroSoundBtn" aria-label="Watch with sound">
    <svg class="sound-icon sound-icon-off" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"/>
      <path d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"/>
    </svg>
    <svg class="sound-icon sound-icon-on" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
      <path d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"/>
      <path d="M15.536 8.464a5 5 0 010 7.072"/>
      <path d="M18.364 5.636a9 9 0 010 12.728"/>
    </svg>
    <span class="sound-label" id="heroSoundLabel">Watch with Sound</span>
  </button>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('heroSoundBtn');
    const iconOff = document.querySelector('.sound-icon-off') as HTMLElement;
    const iconOn = document.querySelector('.sound-icon-on') as HTMLElement;
    const label = document.getElementById('heroSoundLabel');
    const contentOverlay = document.getElementById('heroContentOverlay');
    const gradientOverlay = document.getElementById('heroGradientOverlay');
    const videoContainer = document.getElementById('heroVideoContainer');
    const iframe = document.getElementById('heroVideo') as HTMLIFrameElement;

    let isMuted = true;

    btn?.addEventListener('click', () => {
      if (isMuted) {
        // UNMUTE: fade out overlays, switch iframe to controls + unmute, resize to fit
        isMuted = false;
        if (iconOff) iconOff.style.display = 'none';
        if (iconOn) iconOn.style.display = 'block';
        if (label) label.textContent = 'Return to Page';

        contentOverlay?.classList.add('faded-out');
        gradientOverlay?.classList.add('faded-out');
        videoContainer?.classList.add('video-watching');

        // Swap iframe src: unmute + show controls
        if (iframe) {
          iframe.src = iframe.src
            .replace('controls=0', 'controls=1')
            .replace('mute=1', 'mute=0');
        }
      } else {
        // MUTE: restore overlays, switch iframe back to muted bg mode
        isMuted = true;
        if (iconOff) iconOff.style.display = 'block';
        if (iconOn) iconOn.style.display = 'none';
        if (label) label.textContent = 'Watch with Sound';

        contentOverlay?.classList.remove('faded-out');
        gradientOverlay?.classList.remove('faded-out');
        videoContainer?.classList.remove('video-watching');

        // Swap iframe src: mute + hide controls
        if (iframe) {
          iframe.src = iframe.src
            .replace('controls=1', 'controls=0')
            .replace('mute=0', 'mute=1');
        }
      }
    });
  });
</script>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 620px;
    overflow: hidden;
    background: #0a0a0a;
  }

  /* ── Video Background Layer ── */
  .hero-video-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-video-container {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* Cover-fill trick: oversized iframe centered to eliminate black bars */
  .hero-video-container iframe {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 177.78vh;  /* 16:9 ratio relative to viewport height */
    min-width: 100%;
    height: 56.25vw;  /* 16:9 ratio relative to viewport width */
    min-height: 100%;
    transform: translate(-50%, -50%);
    border: none;
    pointer-events: none; /* Prevent clicks on bg video */
  }

  /* Watching mode: fit iframe inside viewport with controls visible */
  .hero-video-container.video-watching iframe {
    width: 100%;
    height: 100%;
    min-width: unset;
    min-height: unset;
    pointer-events: auto; /* Allow interaction with player */
  }

  .hero-video-container.video-watching {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2xl);
  }

  /* ── Gradient Overlay ── */
  .hero-gradient-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10, 10, 10, 0.92) 0%,
      rgba(10, 10, 10, 0.7) 20%,
      rgba(3, 80, 120, 0.5) 50%,
      rgba(5, 173, 237, 0.3) 80%,
      rgba(5, 173, 237, 0.15) 100%
    );
    transition: opacity 0.5s ease;
    z-index: 1;
  }

  .hero-gradient-overlay.faded-out {
    opacity: 0;
    pointer-events: none;
  }

  /* ── Content Overlay ── */
  .hero-content-overlay {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: calc(var(--nav-height) + var(--space-2xl)) var(--space-lg) var(--space-2xl);
    text-align: center;
    transition: opacity 0.5s ease;
  }

  .hero-content-overlay.faded-out {
    opacity: 0;
    pointer-events: none;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    max-width: 900px;
    padding: var(--space-lg) var(--space-lg);
  }

  .hero-badge {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--cream);
    background: rgba(230, 136, 28, 0.3);
    border: 1px solid rgba(230, 136, 28, 0.5);
    padding: 6px 16px;
    border-radius: 100px;
    backdrop-filter: blur(4px);
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: 900;
    line-height: 1;
    color: var(--cream);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    text-shadow:
      0 2px 8px rgba(0,0,0,0.6),
      0 4px 24px rgba(0,0,0,0.4);
  }

  .hero-subheadline {
    font-family: var(--font-body);
    font-size: var(--text-xl);
    font-weight: 400;
    line-height: 1.5;
    color: rgba(251, 226, 186, 0.95);
    max-width: 700px;
    text-shadow:
      0 1px 4px rgba(0,0,0,0.5),
      0 2px 12px rgba(0,0,0,0.3);
  }

  .hero-cta {
    margin-top: var(--space-md);
    font-size: var(--text-2xl) !important;
    padding: var(--space-lg) var(--space-3xl) !important;
  }

  .hero-context {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 400;
    line-height: 1.6;
    color: rgba(251, 226, 186, 0.85);
    max-width: 1100px;
    margin-top: 0;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }

  /* ── Sound Toggle ── */
  .hero-sound-btn {
    position: absolute;
    bottom: var(--space-xl);
    right: var(--space-xl);
    z-index: 20;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 100px;
    color: white;
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .hero-sound-btn:hover {
    background: rgba(230, 136, 28, 0.6);
    border-color: rgba(230, 136, 28, 0.8);
    transform: scale(1.05);
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }

  .sound-icon {
    display: none;
  }

  .sound-icon-off {
    display: block;
  }

  .sound-icon.hidden {
    display: none !important;
  }

  .sound-icon:not(.hidden).sound-icon-on {
    display: block;
  }

  /* ── Scroll Indicator ── */
  .scroll-indicator {
    position: absolute;
    bottom: var(--space-xl);
    left: 50%;
    transform: translateX(-50%);
    animation: bounce 2s infinite;
  }

  .scroll-arrow {
    color: rgba(251, 226, 186, 0.6);
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(10px); }
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .hero-content {
      padding: var(--space-3xl) var(--space-xl);
      gap: var(--space-lg);
    }

    .hero-content-overlay {
      padding: calc(var(--nav-height) + var(--space-2xl)) var(--space-xl) var(--space-2xl);
    }

    .hero-headline {
      font-size: clamp(2rem, 6vw, 3.5rem);
    }

    .hero-subheadline {
      font-size: var(--text-lg);
    }

    .hero-cta {
      font-size: var(--text-xl) !important;
      padding: var(--space-md) var(--space-2xl) !important;
    }

    .hero-context {
      font-size: var(--text-xs);
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 100vh;
      max-height: unset;
    }

    .hero-headline {
      font-size: clamp(1.8rem, 8vw, 2.5rem);
    }

    .hero-subheadline {
      font-size: var(--text-sm);
      line-height: 1.4;
    }

    .hero-cta {
      font-size: var(--text-base) !important;
      padding: var(--space-sm) var(--space-xl) !important;
    }

    .hero-context {
      font-size: var(--text-xs);
      line-height: 1.5;
    }

    .hero-content {
      padding: var(--space-lg) var(--space-md);
      gap: var(--space-md);
    }

    .hero-content-overlay {
      padding-top: calc(var(--nav-height) + var(--space-sm));
      padding-bottom: var(--space-xl);
    }

    .hero-badge {
      font-size: 9px;
      padding: 4px 12px;
      letter-spacing: 0.15em;
    }

    .hero-sound-btn {
      bottom: var(--space-md);
      right: var(--space-sm);
      padding: 6px 12px;
      font-size: 9px;
    }

    .hero-video-container.video-watching {
      padding: var(--space-lg);
    }
  }
</style>
