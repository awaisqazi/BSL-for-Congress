---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="anointment" id="anointment">
  <div class="anointment-bg">
    <div class="anointment-pattern"></div>
  </div>
  
  <div class="container anointment-content">
    <div class="anointment-inner">
      <span class="anointment-label animate-in" data-i18n="anointment.label">Why Independent?</span>
      
      <h2 class="anointment-headline animate-in" data-i18n="anointment.headline">
        The Anointment
      </h2>
      
      <p class="anointment-text animate-in" data-i18n="anointment.text">
        When Rep. Jesús "Chuy" García announced his retirement, he didn't give voters a choice. He filed for a fifth term, then moments before the filing deadline, his former chief of staff filed nominating petitions collected in just days. García withdrew and endorsed her, handing the seat to an uncontested successor. She needed only 697 signatures. Independent candidates must collect over 10,816. This is not democracy. This is an anointment.
      </p>

      <a href="https://www.chicagotribune.com/2026/03/20/illinois-4th-congressional-district-independents/" class="btn btn-orange anointment-cta animate-in" target="_blank" rel="noopener" data-i18n="anointment.cta">
        Learn About the Subversion
      </a>
    </div>

    <!-- Side image accent -->
    <div class="anointment-image-wrap animate-in">
      <img 
        src={`${base}/images/Chuy Garcia.jpeg`} 
        alt="U.S. Rep. Jesús 'Chuy' García speaks during a press conference at the Illinois Coalition for Immigrant and Refugee Rights headquarters in the Loop on Sept. 28, 2025."
        class="anointment-image"
        loading="lazy"
      />
      <cite class="photo-credit">Eileen T. Meslar / Chicago Tribune</cite>
    </div>
  </div>
</section>

<style>
  .anointment {
    position: relative;
    overflow: hidden;
    padding: var(--space-4xl) 0;
  }

  .anointment-bg {
    position: absolute;
    inset: 0;
    background: var(--blue);
    z-index: 0;
  }

  .anointment-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.05;
    background-image: 
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 20px,
        rgba(255,255,255,0.1) 20px,
        rgba(255,255,255,0.1) 21px
      );
  }

  .anointment-content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .anointment-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .anointment-label {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--gold-soft);
  }

  .anointment-headline {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 900;
    line-height: 1;
    color: var(--cream);
    text-transform: uppercase;
  }

  .anointment-text {
    font-size: var(--text-lg);
    line-height: 1.75;
    color: #ffffff;
  }

  .anointment-cta {
    align-self: flex-start;
    margin-top: var(--space-sm);
  }

  .anointment-image-wrap {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
  }

  .anointment-image-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    border: 3px solid var(--orange);
    border-radius: var(--radius-lg);
    pointer-events: none;
  }

  .anointment-image {
    width: 100%;
    height: 400px;
    object-fit: cover;
  }

  .photo-credit {
    position: absolute;
    bottom: 8px;
    right: 10px;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-style: normal;
    color: rgba(255, 255, 255, 0.75);
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(4px);
    padding: 3px 8px;
    border-radius: 4px;
    letter-spacing: 0.02em;
    z-index: 2;
  }

  /* Diagonal edge at top */
  .anointment::before {
    content: '';
    position: absolute;
    top: -30px;
    left: 0;
    right: 0;
    height: 60px;
    background: var(--cream-light);
    transform: skewY(-1.5deg);
    z-index: 1;
  }

  /* Diagonal edge at bottom */
  .anointment::after {
    content: '';
    position: absolute;
    bottom: -30px;
    left: 0;
    right: 0;
    height: 60px;
    background: var(--cream);
    transform: skewY(-1.5deg);
    z-index: 1;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .anointment {
      padding: var(--space-5xl) 0 var(--space-4xl);
    }

    .anointment-content {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .anointment-image {
      height: 350px;
    }
  }

  @media (max-width: 768px) {
    .anointment-content {
      grid-template-columns: 1fr;
    }

    .anointment-image {
      height: 250px;
    }

    .anointment-headline {
      font-size: var(--text-3xl);
    }
  }
</style>
