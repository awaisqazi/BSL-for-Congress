---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="platform-hero" id="platform-hero" style={`background-image: url('${base}/images/platform-hero-placeholder.png')`}>
  <div class="platform-hero-overlay"></div>
  <div class="platform-hero-noise"></div>
  
  <div class="platform-hero-content container">
    <span class="platform-hero-badge animate-in">THE WORKING-CLASS AGENDA • IL-04</span>
    
    <h1 class="platform-hero-headline animate-in" data-i18n="issues.hero_headline">
      A Platform for Working People, Not the Billionaire Class.
    </h1>
    
    <p class="platform-hero-sub animate-in" data-i18n="issues.hero_sub">
      Byron is fighting to guarantee a baseline standard of dignity for working families, seniors, teachers, and marginalized groups across IL-04.
    </p>
  </div>
</section>

<style>
  .platform-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-size: cover;
    background-position: center top;
    background-attachment: fixed;
    overflow: hidden;
    padding-top: var(--nav-height);
  }

  @media (max-width: 768px) {
    .platform-hero {
      background-attachment: scroll;
      min-height: 60vh;
    }
  }

  .platform-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      rgba(5, 173, 237, 0.92) 0%,
      rgba(3, 109, 153, 0.88) 40%,
      rgba(26, 26, 26, 0.82) 100%
    );
    z-index: 1;
  }

  .platform-hero-noise {
    position: absolute;
    inset: 0;
    z-index: 2;
    opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    pointer-events: none;
  }

  .platform-hero-content {
    position: relative;
    z-index: 3;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    max-width: 900px;
    padding: var(--space-4xl) var(--space-lg);
  }

  .platform-hero-badge {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--cream);
    background: rgba(230, 136, 28, 0.3);
    border: 1px solid rgba(230, 136, 28, 0.5);
    padding: 6px 16px;
    border-radius: 100px;
    backdrop-filter: blur(4px);
  }

  .platform-hero-headline {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: 900;
    line-height: 1.05;
    color: var(--cream);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    text-shadow: 0 4px 30px rgba(0,0,0,0.3);
  }

  .platform-hero-sub {
    font-family: var(--font-body);
    font-size: var(--text-xl);
    font-weight: 400;
    line-height: 1.6;
    color: #ffffff;
    max-width: 720px;
  }

  @media (max-width: 768px) {
    .platform-hero-headline {
      font-size: var(--text-4xl);
    }
    .platform-hero-content {
      padding: var(--space-3xl) var(--space-md);
    }
  }
</style>
