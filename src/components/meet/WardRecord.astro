---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="ward-record" id="ward-record">
  <!-- Blue context banner -->
  <div class="record-banner">
    <div class="record-banner-bg">
      <div class="record-banner-pattern"></div>
    </div>
    <div class="container record-banner-content">
      <div class="record-banner-text">
        <span class="record-banner-year animate-in" data-i18n="meet.record_kicker">Making Illinois Home</span>
        <h2 class="record-banner-headline animate-in" data-i18n="meet.record_headline">Teacher, Researcher, Organizer</h2>
        <p class="record-banner-desc animate-in" data-i18n="meet.record_desc">
          Byron became an adult education teacher at the University of Illinois at Chicago and founded the UIC Center for Literacy's Spanish literacy program, making the GED program at UIC much more widely accessible to Spanish speaking immigrants and residents. Seeing the need for wrap-around services, Byron also brought a case worker into the program to ensure his students' families received resources and needed services.
        </p>
        <p class="record-banner-desc animate-in" data-i18n="meet.record_desc2">
          In addition to Byron's work as a teacher, he also volunteered as a youth soccer coach at Pilsen Academy. Byron earned a Master's Degree in Economics from UIC while also working as a lead researcher. He began collaborating alongside the Chicago Teachers Union in investigating the financial relationships between charter school networks like UNO, school funding, and Chicago's political elite, and organized with parents and teachers like Karen Lewis to fight for fully funded public schools.
        </p>
      </div>
      <div class="record-banner-image-wrap animate-in">
        <img 
          src={`${base}/images/byron-school-rally.jpg`} 
          alt="Byron speaking at a press conference demanding investment in neighborhood schools"
          class="record-banner-image"
          loading="lazy"
        />
        <span class="record-image-caption" data-i18n="meet.caption_schools">Fighting for investment in our neighborhood schools</span>
      </div>
    </div>
  </div>

  <!-- Milestones -->
  <div class="record-cards-section">
    <div class="container">
      <span class="section-label animate-in" data-i18n="meet.milestones_label" style="text-align:center;display:block;">The Path to Public Service</span>
      <div class="record-grid">
        <!-- School Closings -->
        <div class="record-card animate-in">
          <div class="record-card-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <!-- School Building -->
              <path d="m4 6 8-4 8 4"/>
              <path d="m18 10 4 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-8l4-2"/>
              <path d="M14 22v-4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v4"/>
              <path d="M18 5v17"/>
              <path d="M6 5v17"/>
              <circle cx="12" cy="9" r="2"/>
            </svg>
          </div>
          <h3 class="record-card-title" data-i18n="meet.schools_title">Fighting School Closures</h3>
          <p class="record-card-desc" data-i18n="meet.schools_desc">
            After Rahm Emanuel announced that he would be closing a hundred thirty Chicago Public Schools, Byron became involved in the Pilsen Alliance where he organized with the community to push to keep the schools open.
          </p>
        </div>

        <!-- 2015 Alderman Run -->
        <div class="record-card animate-in">
          <div class="record-card-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <!-- Voting/Check Square -->
              <polyline points="9 11 12 14 22 4" />
              <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
            </svg>
          </div>
          <h3 class="record-card-title" data-i18n="meet.first_run_title">First Run for Alderman</h3>
          <p class="record-card-desc" data-i18n="meet.first_run_desc">
            In 2015, Byron was encouraged by community leaders Nellie Cotton and Kit Duffy to run for Alderman against the machine - now disgraced former Alderman Danny Solis. Byron came in second in the 5-way race.
          </p>
        </div>

        <!-- Pilsen Alliance Director -->
        <div class="record-card animate-in">
          <div class="record-card-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <!-- Map Pin/Neighborhood Defense -->
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <h3 class="record-card-title" data-i18n="meet.alliance_title">Leading the Pilsen Alliance</h3>
          <p class="record-card-desc" data-i18n="meet.alliance_desc">
            Byron eventually served as the Director of Pilsen Alliance where he became a leader and an activist in the fight against gentrification, displacement, and corruption.
          </p>
        </div>

        <!-- DSA & Rent Control -->
        <div class="record-card animate-in">
          <div class="record-card-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <!-- Movement/Users -->
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3 class="record-card-title" data-i18n="meet.dsa_title">Joining the Movement</h3>
          <p class="record-card-desc" data-i18n="meet.dsa_desc">
            He joined forces with organizers from the Chicago Democratic Socialists of America while partnering on the coalition to Lift the Ban on Rent Control across the state of Illinois, and became a member then and there.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .ward-record {
    position: relative;
    overflow: hidden;
  }

  /* Blue Banner */
  .record-banner {
    position: relative;
    padding: var(--space-4xl) 0;
    overflow: hidden;
  }

  .record-banner-bg {
    position: absolute;
    inset: 0;
    background: var(--blue);
    z-index: 0;
  }

  .record-banner-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.05;
    background-image: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 20px,
      rgba(255,255,255,0.1) 20px,
      rgba(255,255,255,0.1) 21px
    );
  }

  .record-banner-content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .record-banner-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .record-banner-year {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--gold-soft);
  }

  .record-banner-headline {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 900;
    line-height: 1;
    color: var(--cream);
    text-transform: uppercase;
  }

  .record-banner-desc {
    font-size: var(--text-lg);
    line-height: 1.75;
    color: #ffffff;
  }

  .record-banner-image-wrap {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
  }

  .record-banner-image {
    width: 100%;
    height: 400px;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .record-image-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 12px 16px;
    background: linear-gradient(transparent, rgba(0,0,0,0.7));
    color: var(--cream);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: italic;
  }

  /* Record Cards */
  .record-cards-section {
    background: var(--cream);
    padding: var(--space-4xl) 0;
  }

  .record-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    margin-top: var(--space-2xl);
  }

  .record-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    box-shadow: var(--shadow-sm);
    border-left: 4px solid var(--orange);
    transition: transform var(--duration-normal) var(--ease-default), box-shadow var(--duration-normal) var(--ease-default);
  }

  .record-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .record-card-icon {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--blue);
    margin-bottom: var(--space-lg);
    background: rgba(5, 173, 237, 0.08); /* Transparent blue matches PlatformGrid */
    border-radius: var(--radius-lg);
    padding: 8px;
    transition: all var(--duration-normal) var(--ease-default);
  }

  .record-card:hover .record-card-icon {
    background: var(--blue);
    color: var(--white);
    transform: scale(1.05);
  }

  .record-card-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--blue);
    margin-bottom: var(--space-md);
  }

  .record-card-desc {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--gray-700);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .record-banner-content {
      grid-template-columns: 1fr;
    }

    .record-banner-image {
      height: 250px;
    }

    .record-grid {
      grid-template-columns: 1fr;
    }

    .record-banner-headline {
      font-size: var(--text-3xl);
    }
  }
</style>
