---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Links | Byron Sigcho-Lopez for Congress" description="Quick links to Byron Sigcho-Lopez's campaign: donate, volunteer, and follow on social media.">
  <main class="links-page">
    <div class="links-bg">
      <div class="links-bg-pattern"></div>
    </div>

    <div class="links-container">
      <!-- Logo & Identity -->
      <div class="links-header animate-in">
        <a href={`${base}/`}>
          <img src={`${base}/BSL_Official.png`} alt="Byron Sigcho-Lopez for Congress" class="links-logo" />
        </a>
        <h1 class="links-name">Byron Sigcho-Lopez</h1>
        <p class="links-tagline">Independent Democratic Socialist • IL-04</p>
      </div>

      <!-- Video Player -->
      <div class="links-video animate-in">
        <div class="links-video-wrap">
          <iframe
            src="https://www.youtube.com/embed/ouSFDZfJu-E?rel=0&modestbranding=1&playsinline=1"
            title="Byron Sigcho-Lopez for Congress"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      </div>

      <!-- Primary Links -->
      <div class="links-list">
        <a href={`${base}/`} class="link-card animate-in" target="_blank" rel="noopener">
          <span class="link-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/>
            </svg>
          </span>
          <span class="link-text">Visit the Official Website</span>
          <span class="link-arrow">→</span>
        </a>

        <a href="https://secure.actblue.com/donate/byronfor04web/" class="link-card link-card-donate animate-in" target="_blank" rel="noopener">
          <span class="link-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
            </svg>
          </span>
          <span class="link-text">Donate: Fund the Fight</span>
          <span class="link-arrow">→</span>
        </a>

        <a href={`${base}/volunteer`} class="link-card animate-in" target="_blank" rel="noopener">
          <span class="link-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </span>
          <span class="link-text">Volunteer: Join the Ground Game</span>
          <span class="link-arrow">→</span>
        </a>

        <a href={`${base}/platform`} class="link-card animate-in" target="_blank" rel="noopener">
          <span class="link-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/>
            </svg>
          </span>
          <span class="link-text">Read the Full Platform</span>
          <span class="link-arrow">→</span>
        </a>

        <a href={`${base}/machine`} class="link-card animate-in" target="_blank" rel="noopener">
          <span class="link-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/>
            </svg>
          </span>
          <span class="link-text">Machine vs. Movement</span>
          <span class="link-arrow">→</span>
        </a>
      </div>

      <!-- Social Media -->
      <div class="links-socials animate-in">
        <a href="https://x.com/BSLForCongress" class="social-btn" target="_blank" rel="noopener" aria-label="X (Twitter)">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://www.instagram.com/bslforcongress/" class="social-btn" target="_blank" rel="noopener" aria-label="Instagram">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="https://www.facebook.com/BSLForCongress/" class="social-btn" target="_blank" rel="noopener" aria-label="Facebook">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="https://www.tiktok.com/@sigchofor25" class="social-btn" target="_blank" rel="noopener" aria-label="TikTok">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.71a8.35 8.35 0 0 0 4.76 1.49V6.75a4.84 4.84 0 0 1-1-.06z"/></svg>
        </a>
        <a href="https://www.youtube.com/@BSLforCongress" class="social-btn" target="_blank" rel="noopener" aria-label="YouTube">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      </div>

      <!-- Divider -->
      <div class="links-divider animate-in">
        <span class="links-divider-text">Join the Movement</span>
      </div>

      <!-- Volunteer Signup Form -->
      <div class="links-form-wrap animate-in">
        <form class="links-form" id="links-volunteer-form" action="https://docs.google.com/forms/d/e/1FAIpQLSeUKnQVp4auTqHdFZeDrGlAOYAjmOO0sE19Xm11Pee2ayuuWQ/formResponse" method="POST" target="hidden_iframe_links">
          <div class="links-form-row">
            <div class="links-form-group">
              <label for="links-first-name">First Name *</label>
              <input type="text" id="links-first-name" name="entry.661274230" required />
            </div>
            <div class="links-form-group">
              <label for="links-last-name">Last Name *</label>
              <input type="text" id="links-last-name" name="entry.449873967" required />
            </div>
          </div>

          <div class="links-form-group">
            <label for="links-email">Email *</label>
            <input type="email" id="links-email" name="entry.378191335" required />
          </div>

          <div class="links-form-row links-form-row-3">
            <div class="links-form-group">
              <label for="links-phone">Mobile Phone *</label>
              <input type="tel" id="links-phone" name="entry.763325091" required />
            </div>
            <div class="links-form-group">
              <label for="links-city">City *</label>
              <input type="text" id="links-city" name="entry.113002180" required />
            </div>
            <div class="links-form-group">
              <label for="links-zip">ZIP Code *</label>
              <input type="text" id="links-zip" name="entry.1587719447" pattern="[0-9]{5}" maxlength="5" required />
            </div>
          </div>

          <fieldset class="links-checkboxes">
            <legend>How would you like to help?</legend>
            <div class="links-checkbox-grid">
              <label class="links-cb"><input type="checkbox" name="entry.1014527396" value="Collect Petition Signatures" /><span>Collect Petition Signatures</span></label>
              <label class="links-cb"><input type="checkbox" name="entry.1014527396" value="Knock on Doors" /><span>Knock on Doors</span></label>
              <label class="links-cb"><input type="checkbox" name="entry.1014527396" value="Phone/Text Banking" /><span>Phone/Text Banking</span></label>
              <label class="links-cb"><input type="checkbox" name="entry.1014527396" value="Host a Meet & Greet" /><span>Host a Meet & Greet</span></label>
              <label class="links-cb"><input type="checkbox" name="entry.1014527396" value="Bilingual Outreach (I speak Spanish / Yo hablo español)" /><span>Bilingual Outreach</span></label>
              <label class="links-cb"><input type="checkbox" name="entry.1014527396" value="Post on Social Media" /><span>Post on Social Media</span></label>
              <label class="links-cb"><input type="checkbox" name="entry.1014527396" value="Precinct Captain / Volunteer" /><span>Precinct Captain / Volunteer</span></label>
              <label class="links-cb"><input type="checkbox" name="entry.1014527396" value="High School Ambassador" /><span>High School Ambassador</span></label>
              <label class="links-cb"><input type="checkbox" name="entry.1014527396" value="College Campus Captain / Volunteer" /><span>College Campus Captain / Volunteer</span></label>
              <label class="links-cb"><input type="checkbox" name="entry.1014527396" value="Help Create Marketing Collateral (Graphic Design)" /><span>Marketing / Graphic Design</span></label>
              <label class="links-cb"><input type="checkbox" name="entry.1014527396" value="Help Create Campaign Videos (Videography / Video Editing)" /><span>Videography / Video Editing</span></label>
            </div>
          </fieldset>

          <p class="links-compliance">
            By submitting, you agree to receive periodic campaign updates via SMS. Message and data rates may apply. Text STOP to unsubscribe.
          </p>

          <button type="submit" class="btn btn-orange links-submit">
            Join the Movement ✊
          </button>

          <p class="links-success" id="links-success">Thank you for stepping up! We'll be in touch soon. ✊</p>
          <iframe name="hidden_iframe_links" id="hidden_iframe_links" style="display:none;"></iframe>
        </form>
      </div>

      <!-- Footer -->
      <div class="links-footer animate-in">
        <p>Paid for by Byron Sigcho-Lopez for Congress</p>
      </div>
    </div>
  </main>
</Layout>

<script>
  const form = document.getElementById('links-volunteer-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('links-success');

  if (form) {
    form.addEventListener('submit', function () {
      setTimeout(function () {
        form.reset();
        if (successMsg) {
          successMsg.classList.add('visible');
          setTimeout(function () {
            successMsg.classList.remove('visible');
          }, 5000);
        }
      }, 500);
    });
  }
</script>

<style>
  /* ── Page Background ── */
  .links-page {
    position: relative;
    min-height: 100vh;
    display: flex;
    justify-content: center;
    padding: var(--space-3xl) var(--space-lg);
  }

  .links-bg {
    position: fixed;
    inset: 0;
    background: linear-gradient(
      160deg,
      #03466a 0%,
      #024a72 25%,
      #0a1628 60%,
      #0d0d0d 100%
    );
    z-index: 0;
  }

  .links-bg-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
  }

  /* ── Container ── */
  .links-container {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 480px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
  }

  /* ── Header ── */
  .links-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .links-logo {
    width: 100px;
    height: auto;
    filter: brightness(1.1);
    transition: transform var(--duration-normal) var(--ease-default);
  }

  .links-logo:hover {
    transform: scale(1.05);
  }

  .links-name {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 900;
    color: var(--cream);
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }

  .links-tagline {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-soft);
  }

  /* ── Video Player ── */
  .links-video {
    width: 100%;
  }

  .links-video-wrap {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 */
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
    transition: box-shadow var(--duration-normal) var(--ease-default), border-color var(--duration-normal) var(--ease-default);
  }

  .links-video-wrap:hover {
    border-color: rgba(230, 136, 28, 0.4);
    box-shadow: 0 8px 32px rgba(230, 136, 28, 0.12);
  }

  .links-video-wrap iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  /* ── Link Cards ── */
  .links-list {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .link-card {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    width: 100%;
    padding: 16px 20px;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    color: #ffffff;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    transition: all var(--duration-normal) var(--ease-default);
  }

  .link-card:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  .link-card-donate {
    background: linear-gradient(135deg, rgba(230, 136, 28, 0.2) 0%, rgba(230, 136, 28, 0.08) 100%);
    border-color: rgba(230, 136, 28, 0.35);
  }

  .link-card-donate:hover {
    background: linear-gradient(135deg, rgba(230, 136, 28, 0.35) 0%, rgba(230, 136, 28, 0.15) 100%);
    border-color: rgba(230, 136, 28, 0.55);
    box-shadow: 0 8px 24px rgba(230, 136, 28, 0.15);
  }

  .link-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    background: rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-md);
    color: var(--gold-soft);
  }

  .link-card-donate .link-icon {
    color: var(--orange-light);
  }

  .link-text {
    flex: 1;
  }

  .link-arrow {
    font-size: var(--text-lg);
    opacity: 0.4;
    transition: opacity var(--duration-fast) var(--ease-default), transform var(--duration-fast) var(--ease-default);
  }

  .link-card:hover .link-arrow {
    opacity: 0.8;
    transform: translateX(3px);
  }

  /* ── Social Media Row ── */
  .links-socials {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    transition: all var(--duration-normal) var(--ease-default);
  }

  .social-btn:hover {
    background: rgba(230, 136, 28, 0.3);
    border-color: rgba(230, 136, 28, 0.6);
    color: #ffffff;
    transform: translateY(-3px) scale(1.08);
    box-shadow: 0 6px 20px rgba(230, 136, 28, 0.2);
  }

  /* ── Divider ── */
  .links-divider {
    width: 100%;
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .links-divider::before,
  .links-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.12);
  }

  .links-divider-text {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--gold-soft);
    white-space: nowrap;
  }

  /* ── Form ── */
  .links-form-wrap {
    width: 100%;
  }

  .links-form {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }

  .links-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm);
  }

  .links-form-row-3 {
    grid-template-columns: 1fr 1fr 1fr;
  }

  .links-form-group {
    margin-bottom: var(--space-md);
  }

  .links-form-group label {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--gold-soft);
    margin-bottom: 4px;
    letter-spacing: 0.03em;
  }

  .links-form-group input {
    width: 100%;
    padding: 10px 14px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.06);
    color: #ffffff;
    transition: border-color var(--duration-fast) var(--ease-default), box-shadow var(--duration-fast) var(--ease-default);
    box-sizing: border-box;
  }

  .links-form-group input::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  .links-form-group input:focus {
    outline: none;
    border-color: var(--orange);
    box-shadow: 0 0 0 3px rgba(230, 136, 28, 0.15);
  }

  /* Checkboxes */
  .links-checkboxes {
    border: none;
    padding: 0;
    margin: 0 0 var(--space-md) 0;
  }

  .links-checkboxes legend {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--gold-soft);
    margin-bottom: var(--space-sm);
  }

  .links-checkbox-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
  }

  .links-cb {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 8px;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background var(--duration-fast) var(--ease-default);
  }

  .links-cb:hover {
    background: rgba(255, 255, 255, 0.04);
  }

  .links-cb input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: var(--orange);
    cursor: pointer;
    flex-shrink: 0;
  }

  .links-cb span {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.3;
  }

  .links-compliance {
    font-size: 10px;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.35);
    margin-bottom: var(--space-md);
  }

  .links-submit {
    width: 100%;
    font-size: var(--text-base) !important;
    padding: 14px 24px !important;
    cursor: pointer;
    border: none;
    border-radius: var(--radius-md);
  }

  /* Success Message */
  .links-success {
    text-align: center;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--gold-soft);
    margin-top: 0;
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition: opacity 0.4s ease, max-height 0.4s ease, margin-top 0.4s ease;
  }

  .links-success.visible {
    opacity: 1;
    max-height: 60px;
    margin-top: var(--space-md);
  }

  /* ── Footer ── */
  .links-footer {
    text-align: center;
    padding-top: var(--space-md);
  }

  .links-footer p {
    font-family: var(--font-body);
